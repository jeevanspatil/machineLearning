import numpy as np
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans

# Full Lloyd's k-means implementation

def kmeans(X, n_clusters, n_init=10, max_iter=300):
    best_score = None
    best_centers = None
    best_labels = None

    for _ in range(n_init):
        kmeans = KMeans(n_clusters=n_clusters, n_init=1, max_iter=max_iter)
        kmeans.fit(X)
        if best_score is None or kmeans.inertia_ < best_score:
            best_score = kmeans.inertia_
            best_centers = kmeans.cluster_centers_
            best_labels = kmeans.labels_

    return best_centers, best_labels

